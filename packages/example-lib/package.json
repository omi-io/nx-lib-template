{
  "name": "@omi-io/example-lib",
  "scopeCommitName": "@:example",
  "version": "0.0.1",
  "description": "Example TypeScript library — replace or remove when bootstrapping a new repo.",
  "license": "MIT",
  "type": "module",
  "types": "./dist/types/index.d.ts",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "private": true,
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "omi-io-pkg clean",
    "build": "yarn clean && omi-io-pkg build && tsc && omi-io-pkg alias",
    "test": "jest",
    "lint": "eslint ./src",
    "tsc-check": "tsc --noEmit --emitDeclarationOnly false"
  },
  "devDependencies": {
    "@omi-io/pkg-scripts": "^2.5.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.0.5",
    "typescript": "^5.4.3"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./package.json": "./package.json",
    "./echo": {
      "types": "./dist/types/echo/index.d.ts",
      "require": "./dist/cjs/echo/index.cjs",
      "default": "./dist/esm/echo/index.js"
    }
  }
}
