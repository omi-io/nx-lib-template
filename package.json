{
  "name": "@omi-io/template",
  "description": "Nx monorepo template for TypeScript libraries with Yarn, CI, and release workflows",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=8.0.0",
    "yarn": ">=4.1.0"
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "scripts": {
    "prepare": "husky install",
    "build": "yarn nx run-many -t build",
    "clean": "yarn nx run-many -t clean",
    "test": "yarn nx run-many -t test",
    "tsc-check": "yarn nx run-many -t tsc-check"
  },
  "devDependencies": {
    "@amollo-lint/commitlint-plugin-card-id": "^1.3.0",
    "@amollo-lint/commitlint-plugin-scope-ws": "^1.1.0",
    "@amollo-lint/eslint-config-ts-prettier": "^1.0.1",
    "@commitlint/cli": "^19.2.1",
    "@commitlint/config-conventional": "^19.1.0",
    "@nx/eslint": "22.7.1",
    "@omi-io/pkg-scripts": "v2.5.0",
    "@types/fs-extra": "^11",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.11.30",
    "cz-conventional-changelog": "^3.3.0",
    "esbuild": "^0.20.2",
    "eslint": "^8.57.0",
    "fs-extra": "^11.2.0",
    "husky": "^9.0.11",
    "jest": "^29.5.0",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.2",
    "nx": "22.7.1",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.0.5",
    "tsx": "^4.7.2",
    "typescript": "^5.4.3"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.js": "eslint --cache --fix",
    "*.mjs": "eslint --cache --fix",
    "(src|spec)/**/*.ts": [
      "eslint --fix"
    ]
  },
  "packageManager": "yarn@4.1.0"
}
